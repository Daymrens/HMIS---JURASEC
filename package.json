{
  "name": "jurasec-pos",
  "version": "1.0.0",
  "description": "Jurasec Enterprises - Hardware & Construction Supplies Management System with POS",
  "main": "dist-electron/main.js",
  "author": "Jurasec Enterprises",
  "license": "ISC",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node build-electron.js && electron-builder",
    "preview": "vite preview",
    "electron:dev": "NODE_ENV=production vite build && node build-electron.js && electron .",
    "electron:build": "vite build && node build-electron.js && electron-builder",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.9.0",
    "jspdf": "^2.5.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.1.3",
    "recharts": "^2.15.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "esbuild": "^0.28.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  },
  "build": {
    "appId": "com.jurasec.pos",
    "productName": "Jurasec POS",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/better-sqlite3/**/*"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
